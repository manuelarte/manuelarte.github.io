---
interface Linters {
    name: string;
    description: string;
    link: {
        url?: string;
        target?: string;
        title?: string;
        buttonLabel?: string;
    };
}

const linters: Linters[] = [{
    name: 'funcorder',
    description: 'Go Linter 🧐 (available in golangci-lint) that checks the order of methods and constructors.',
    link: {
        url: 'https://github.com/manuelarte/funcorder/',
    }
}, {
    name: 'embeddedstructfieldcheck',
    description: ' Go Linter 🧐 (available in golangci-lint) that checks that embedded fields should be at the top of the field list of a struct, and there must be an empty line separating embedded fields from regular fields.\n' +
        'Topics',
    link: {
        url: 'https://github.com/manuelarte/embeddedstructfieldcheck',
    }
}, {
    name: 'goddddlint',
    description: 'Go Linter 🧐 that checks domain structs honor best practices.',
    link: {
        url: 'https://github.com/manuelarte/goddddlint'
    },
}, {
    name: 'structinit',
    description: 'Go Linter 🧐 to ensure struct\'s field initialization order matches struct\'s field declaration.',
    link: {
        url: 'https://github.com/manuelarte/structinit'
    },
}, {
    name: 'funcorder-rs',
    description: '🦀 Rust Linter 🧐 to check that methods are ordered as constructor-public-private.',
    link: {
        url: 'https://github.com/manuelarte/funcorder-rs'
    },
}];
---

<div>
    <!-- <h2 class="text-2xl font-bold text-white mb-4">Latest Projects</h2> -->

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        {linters.map(linter =>

            <div class="flex flex-col justify-center items-start border border-gray-700 rounded-lg p-4 bg-black">

                <h3 class="text-xl font-semibold text-white mb-2">
                    {linter.name}
                </h3>

                <p class="text-gray-400">
                    {linter.description}
                </p>

                {
                    linter.link?.url ?
                        <a
                            href={linter.link.url}
                            title={linter.link.title || linter.name}
                            target={linter.link.target || '_blank'}
                            class="
                                w-full px-4 py-2.5 mt-4 text-center

                                border border-gray-600 rounded-lg

                                hover:text-primary
                                hover:border-primary
                            ">
                            {linter.link.buttonLabel || 'Repository'}
                        </a>
                    : null
                }

            </div>

        )}

    </div>

</div>
